      "start": 7.958,
      "end": 8.77
    },
    {
      "text": "我們也使用了",
      "start": 8.77,
      "end": 9.744
    },
    {
      "text": "StandardScaler",
      "start": 9.744,
      "end": 12.018
    },
    {
      "text": "進行特徵縮放。",
      "start": 12.018,
      "end": 12.992
    }
  ],
  "13": [
    {
      "text": "在第四階段，",
      "start": 0.0,
      "end": 0.952
    },
    {
      "text": "我們進行共線性分析。",
      "start": 0.952,
      "end": 2.666
    },
    {
      "text": "計算變異數膨脹因子",
