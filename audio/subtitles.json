      "start": 4.363,
      "end": 5.312
    },
    {
      "text": "ROI、",
      "start": 5.312,
      "end": 5.881
    },
    {
      "text": "行銷支出比例與研發",
      "start": 5.881,
      "end": 7.588
    },
    {
      "text": "支出比例等衍生特徵，",
      "start": 7.588,
      "end": 9.295
    },
    {
      "text": "以幫助模型捕捉更",
      "start": 9.295,
      "end": 10.813
