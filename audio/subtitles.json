      "end": 10.498
    },
    {
      "text": "LightGBM。",
      "start": 10.498,
      "end": 11.733
    }
  ],
  "16": [
    {
      "text": "第七階段是模型評估。",
      "start": 0.0,
      "end": 1.673
    },
    {
      "text": "我們使用",
      "start": 1.673,
      "end": 2.417
    },
    {
      "text": "R²、",
      "start": 2.417,
      "end": 2.789
    },
    {
      "text": "平均絕對誤差",
      "start": 2.789,
      "end": 3.904
    },
    {
      "text": "MAE",
      "start": 3.904,
