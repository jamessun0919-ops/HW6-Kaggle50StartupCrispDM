    },
    {
      "text": "RMSE",
      "start": 5.577,
      "end": 6.321
    },
    {
      "text": "作為評估指標，",
      "start": 6.321,
      "end": 7.436
    },
    {
      "text": "並進行五折交叉驗證。",
      "start": 7.436,
      "end": 9.109
    },
    {
      "text": "梯度提升迴歸在測試集上",
      "start": 9.109,
      "end": 11.154
    },
    {
      "text": "取得了最優的預測表現。",
      "start": 11.154,
      "end": 13.013
    }
  ],
  "17": [
