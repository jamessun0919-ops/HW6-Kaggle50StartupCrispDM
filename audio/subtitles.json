  "4": [
    {
      "text": "第一階段是商業理解。",
      "start": 0.0,
      "end": 1.748
    },
    {
      "text": "企業管理者最關心",
      "start": 1.748,
      "end": 3.301
    },
    {
      "text": "的是如何提升利潤、",
      "start": 3.301,
      "end": 4.854
    },
    {
      "text": "如何分配有限預算，",
      "start": 4.854,
      "end": 6.408
    },
    {
      "text": "以及哪些投資最值得投入。",
      "start": 6.408,
      "end": 8.543
    },
    {
      "text": "我們將預測未來獲利並最佳化預算。",
      "start": 8.543,
      "end": 11.456
    }
  ],
  "5": [
    {
      "text": "我們提出五個商業問題與假說：",
      "start": 0.0,
      "end": 2.599
    },
    {
      "text": "研發支出與利潤是否呈強烈正相關？",
      "start": 2.599,
      "end": 5.598
    },
    {
      "text": "行銷支出影響如何？",
      "start": 5.598,
      "end": 7.197
    },
    {
      "text": "行政支出是否只是成本中心？",
      "start": 7.197,
      "end": 9.596
    },
    {
      "text": "不同州別是否對利潤有實質影響？",
      "start": 9.596,
      "end": 12.395
    }
  ],
  "6": [
    {
      "text": "專案的商業成功標準在於找出",
      "start": 0.0,
      "end": 2.571
    },
    {
      "text": "關鍵獲利因子並提供配置建議。",
      "start": 2.571,
      "end": 5.141
    },
    {
      "text": "技術成功標準則是模型決定係數",
      "start": 5.141,
      "end": 7.909
    },
    {
      "text": "R²",
      "start": 7.909,
      "end": 8.305
    },
    {
      "text": "大於百分之九十、",
      "start": 8.305,
      "end": 9.689
    },
    {
      "text": "最小化均方根誤差，",
      "start": 9.689,
      "end": 11.271
    },
    {
      "text": "並確保模型的可解釋性。",
      "start": 11.271,
      "end": 13.248
    }
  ],
  "7": [
    {
      "text": "第二階段是數據理解。",
      "start": 0.0,
      "end": 1.755
    },
    {
      "text": "數據集包含",
      "start": 1.755,
      "end": 2.731
    },
    {
      "text": "50",
      "start": 2.731,
      "end": 3.121
    },
    {
      "text": "筆記錄，",
      "start": 3.121,
      "end": 3.706
    },
    {
      "text": "特徵包括研發支出、",
      "start": 3.706,
      "end": 5.266
    },
    {
      "text": "行政支出、",
      "start": 5.266,
      "end": 6.046
    },
    {
      "text": "行銷支出、",
      "start": 6.046,
      "end": 6.827
    },
    {
      "text": "州別以及目標變數利潤。",
      "start": 6.827,
      "end": 8.777
    },
    {
      "text": "我們首先進行數據加",
      "start": 8.777,
      "end": 10.533
    },
    {
      "text": "載與基本統計量檢查。",
      "start": 10.533,
      "end": 12.288
    }
  ],
  "8": [
    {
      "text": "接著進行數據質量檢查，",
      "start": 0.0,
      "end": 1.904
    },
    {
      "text": "確認無缺失值與重複記錄。",
      "start": 1.904,
      "end": 3.999
    },
    {
      "text": "單變數分析顯示，",
      "start": 3.999,
      "end": 5.331
    },
    {
      "text": "利潤大致呈常態分佈，",
      "start": 5.331,
      "end": 7.045
    },
    {
      "text": "且無明顯的異常離群值。",
      "start": 7.045,
      "end": 8.949
    },
    {
      "text": "我們也分析了研發、",
      "start": 8.949,
      "end": 10.472
    },
    {
      "text": "行銷和行政支出的分佈特徵。",
      "start": 10.472,
      "end": 12.757
    }
  ],
  "9": [
    {
      "text": "雙變數分析中，",
      "start": 0.0,
      "end": 1.193
    },
    {
      "text": "我們繪製散佈圖與相關係數矩陣。",
      "start": 1.193,
      "end": 3.978
    },
    {
      "text": "可以發現，",
      "start": 3.978,
      "end": 4.773
    },
    {
      "text": "研發支出與利潤呈現極高的正相關，",
      "start": 4.773,
      "end": 7.757
    },
    {
      "text": "行銷支出呈中度正相關，",
      "start": 7.757,
      "end": 9.746
    },
    {
      "text": "而行政支出與利潤",
      "start": 9.746,
      "end": 11.337
    },
    {
      "text": "的相關性則非常低。",
      "start": 11.337,
      "end": 12.928
    }
  ],
  "10": [
    {
      "text": "對州別進行箱形圖分析",
      "start": 0.0,
      "end": 1.988
    },
    {
      "text": "與單因子變異數分析，",
      "start": 1.988,
      "end": 3.777
    },
    {
      "text": "結果顯示不同州別之間的利",
      "start": 3.777,
      "end": 6.162
    },
    {
      "text": "潤差異在統計上並不顯著。",
      "start": 6.162,
      "end": 8.349
    },
    {
      "text": "異常值分析也確認數據集中",
      "start": 8.349,
      "end": 10.735
    },
    {
      "text": "僅有一筆極低獲利的離群值。",
      "start": 10.735,
      "end": 13.12
    }
  ],
  "11": [
    {
      "text": "第三階段是數據準備。",
      "start": 0.0,
      "end": 1.657
    },
    {
      "text": "我們進行特徵工程，",
      "start": 1.657,
      "end": 3.13
    },
    {
      "text": "新增了總支出、",
      "start": 3.13,
      "end": 4.235
    },
    {
      "text": "投資報酬率",
      "start": 4.235,
      "end": 5.155
    },
    {
      "text": "ROI、",
      "start": 5.155,
      "end": 5.708
    },
    {
      "text": "行銷支出比例與研發",
      "start": 5.708,
      "end": 7.365
    },
    {
      "text": "支出比例等衍生特徵，",
      "start": 7.365,
      "end": 9.022
    },
    {
      "text": "以幫助模型捕捉更",
      "start": 9.022,
      "end": 10.495
    },
    {
      "text": "多商業維度的資訊。",
      "start": 10.495,
      "end": 11.968
    }
  ],
  "12": [
    {
      "text": "我們將類別變數州別進行獨熱編碼，",
      "start": 0.0,
      "end": 2.28
    },
    {
      "text": "並以八比二的比例切",
      "start": 2.28,
      "end": 3.648
    },
    {
      "text": "分訓練集與測試集。",
      "start": 3.648,
      "end": 4.864
    },
    {
      "text": "對於套用正規化的模型，",
      "start": 4.864,
      "end": 6.384
    },
    {
      "text": "如",
      "start": 6.384,
      "end": 6.536
    },
    {
      "text": "Lasso",
      "start": 6.536,
      "end": 7.296
    },
    {
      "text": "和",
      "start": 7.296,
      "end": 7.448
    },
    {
      "text": "Ridge，",
      "start": 7.448,
      "end": 8.208
    },
    {
      "text": "我們也使用了",
      "start": 8.208,
      "end": 9.12
    },
    {
      "text": "StandardScaler",
      "start": 9.12,
      "end": 11.248
    },
    {
      "text": "進行特徵縮放。",
      "start": 11.248,
      "end": 12.16
    }
  ],
  "13": [
    {
      "text": "在第四階段，",
      "start": 0.0,
      "end": 0.919
    },
    {
      "text": "我們進行共線性分析。",
      "start": 0.919,
      "end": 2.574
    },
    {
      "text": "計算變異數膨脹因子",
      "start": 2.574,
      "end": 4.228
    },
    {
      "text": "VIF，",
      "start": 4.228,
      "end": 4.78
    },
    {
      "text": "確認研發支出與行銷支出等主要特",
      "start": 4.78,
      "end": 7.538
    },
    {
      "text": "徵之間是否存在嚴重的共線性問題，",
      "start": 7.538,
      "end": 10.295
    },
    {
      "text": "以評估特徵與係數的穩定性。",
      "start": 10.295,
      "end": 12.501
    }
  ],
  "14": [
    {
      "text": "第五階段是特徵選擇。",
      "start": 0.0,
      "end": 1.633
    },
    {
      "text": "我們使用",
      "start": 1.633,
      "end": 2.359
    },
    {
      "text": "Lasso",
      "start": 2.359,
      "end": 3.267
    },
    {
