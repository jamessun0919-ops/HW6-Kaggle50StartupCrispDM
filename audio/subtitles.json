      "end": 5.626
    },
    {
      "text": "RFE",
      "start": 5.626,
      "end": 6.171
    },
    {
      "text": "方法，",
      "start": 6.171,
      "end": 6.534
    },
    {
      "text": "自動選擇最重要的特徵組合，",
      "start": 6.534,
      "end": 8.712
    },
    {
      "text": "並對原始特徵",
      "start": 8.712,
      "end": 9.801
    },
    {
      "text": "and",
      "start": 9.801,
      "end": 10.345
    },
    {
      "text": "衍生特徵進行比較排名。",
      "start": 10.345,
      "end": 12.16
    }
  ],
  "15": [
    {
      "text": "第六階段是建模。",
      "start": 0.0,
      "end": 1.081
    },
    {
      "text": "我們建立了線性迴歸作為基準模型，",
      "start": 1.081,
      "end": 3.396
    },
    {
      "text": "並訓練了",
      "start": 3.396,
      "end": 4.014
    },
